{
  "name": "macroloop",
  "version": "1.0.0",
  "description": "Game macro recorder for emulators and idle games",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "svelte": "^4.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "jimp": "^1.6.0",
    "screenshot-desktop": "^1.15.3",
    "uiohook-napi": "^1.5.0"
  },
  "build": {
    "appId": "com.daniel.macroloop",
    "productName": "MacroLoop",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/@nut-tree-fork/nut-js",
        "to": "app/node_modules/@nut-tree-fork/nut-js"
      },
      {
        "from": "node_modules/uiohook-napi",
        "to": "app/node_modules/uiohook-napi"
      }
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "forceCodeSigning": false
  }
}